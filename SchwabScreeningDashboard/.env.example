# ─────────────────────────────────────────────────────────────────────────────
# Schwab Covered Call Dashboard – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Schwab Developer App credentials
# Obtain from: https://developer.schwab.com
SCHWAB_CLIENT_ID=your_client_id_here
SCHWAB_CLIENT_SECRET=your_client_secret_here

# OAuth redirect URI – must match exactly what you registered in the Schwab app
SCHWAB_REDIRECT_URI=http://127.0.0.1:5000/callback

# Flask session secret key – change this to a long random string
FLASK_SECRET_KEY=change_me_to_a_long_random_string_please

# Path to store the OAuth token file (relative to app.py)
TOKEN_FILE=.schwab_tokens.json
